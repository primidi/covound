{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@covound/db": ["./packages/db"],
      "@covound/db/*": ["./packages/db/src/*"],
      "@covound/ui": ["./packages/ui"],
      "@covound/ui/*": ["./packages/ui/src/*"]
    }
  }
}
