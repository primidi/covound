{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@covound/db": ["./packages/db"],
      "@covound/db/*": ["./packages/db/src/*"],
      "@covound/ui": ["./packages/ui"],
      "@covound/ui/*": ["./packages/ui/*"]
    }
  }
}
