{
  "name": "covound-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "CoVound: Truth and Trust Founder Companion",

  "scripts": {
    "dev:vounder": "pnpm --filter vounder dev",
    "dev:co-vounder": "pnpm --filter co-vounder dev",
    "dev:voundism": "pnpm --filter voundism dev",
    "dev:covounding": "pnpm --filter covounding dev",
    "engine:hunt": "pnpm --filter anomaly-engine start",
    "workflows:up": "tsx scripts/run-workflows.ts",
    "workflows:down": "tsx scripts/revert-workflows.ts",
    "vounder:create": "pnpm --filter vounder bootstrap",
    "db:push": "pnpm --filter @covound/db db:push",
    "db:generate": "pnpm --filter @covound/db db:generate",
    "db:seed": "tsx scripts/seed-qa.ts",
    "db:reset": "tsx scripts/reset-local-db.ts",
    "db:clean": "tsx scripts/truncate-db.ts",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "echo \"Error: no test specified\" ; exit 0",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "keywords": [
    "mcp",
    "security",
    "seo-poisoning",
    "ai-hallucination",
    "hackathon"
  ],
  "author": "Gharis Primada Hariyono",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^25.6.2",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prisma": "^6.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "better-auth": "^1.6.10",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2"
  },
  "pnpm": {
    "overrides": {
      "@prisma/client": "^6.4.1",
      "prisma": "^6.4.1"
    }
  }
}
